# ============================================================================
# FDA Drug-Info RAG — environment
# Copy to .env and fill in secrets. Only OPENAI_API_KEY is required for a real
# LLM; everything else has sensible defaults for `docker compose up`.
# ============================================================================

# ---- LLM provider (llm-provider skill) ----
LLM_PROVIDER=openai            # openai | gemini | groq | ollama | local
GEN_MODEL=gpt-4.1-mini
EMBED_MODEL=text-embedding-3-large   # PRD v3.0: 3072-dim; fix BEFORE growth
EMBED_DIM=3072                 # must match EMBED_MODEL (3-large=3072, 3-small=1536)
OPENAI_API_KEY=               # REQUIRED for real generation
# GEMINI_API_KEY=
# GROQ_API_KEY=
# For ollama: no key; run `ollama serve` + pull a chat + embed model

# ---- retrieval ----
# OpenSearch is the course-parity primary store (BM25 + kNN, hybrid RRF).
# Leave OPENSEARCH_URL empty to fall back to embedded Chroma + rank-bm25.
OPENSEARCH_URL=               # e.g. http://opensearch:9200
OPENSEARCH_INDEX=fda_labels
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
CHROMA_PATH=./chroma_db       # fallback store when OPENSEARCH_URL is empty
TOP_K=8
RERANK_TOP_N=4
MAX_ITERS=3                    # agent loop hard cap
ENABLE_GUARDRAIL=1            # safety guardrail node (first in graph)

# ---- Telegram bot (secondary client — optional; absent token = no bot) ----
TELEGRAM__BOT_TOKEN=          # BotFather token (course naming). Also TELEGRAM_BOT_TOKEN.

# ---- persistence (Postgres, item 2) ----
# Local default is sqlite; docker-compose overrides with Postgres.
DATABASE_URL=sqlite:///./maistorage.db
# docker: postgresql+psycopg://app:app@postgres:5432/maistorage
MEMORY_WINDOW=6               # last-N messages loaded as conversation memory

# ---- openFDA ingestion (item 1) ----
OPENFDA_API_KEY=             # optional; keyless works (240 req/min, 1000/day)

# ---- orchestration (item 3) ----
ENABLE_SCHEDULER=0           # 1 = run the in-process APScheduler fallback
SCHEDULE_MINUTES=1440        # interval for the in-process scheduler (daily)
FDA_DAG_SCHEDULE=@daily      # Airflow DAG schedule (course parity: daily sync)
GROWTH_BATCH_SIZE=25         # labels fetched per continuous-growth run

# ---- caching (Redis, item 7 — optional, degrades gracefully) ----
REDIS_URL=                   # e.g. redis://redis:6379/0 (empty = in-memory LRU)
CACHE_TTL_SECONDS=3600

# ---- observability (Langfuse, item 8 — optional, degrades gracefully) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=               # e.g. http://langfuse:3000
