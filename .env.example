# ---- LLM provider (llm-provider skill) ----
LLM_PROVIDER=gemini            # gemini | openai | groq | ollama
GEN_MODEL=gemini-2.5-flash-lite
EMBED_MODEL=gemini-embedding-001   # Gemini AI Studio embed model (Vertex text-embedding-00x won't work here)
# GEMINI_API_KEY=...
# OPENAI_API_KEY=...
# GROQ_API_KEY=...
# For ollama: no key; run `ollama serve` + pull llama3.1:8b & nomic-embed-text

# ---- retrieval ----
CHROMA_PATH=./chroma_db
TOP_K=8
RERANK_TOP_N=4
MAX_ITERS=3                    # agent loop hard cap
